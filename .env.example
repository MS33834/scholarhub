# Database Configuration
POSTGRES_USER=scholarhub
POSTGRES_PASSWORD=scholarhub
POSTGRES_DB=scholarhub

# Backend Configuration
SCHOLARHUB_DATABASE_URL=postgresql+asyncpg://scholarhub:scholarhub@localhost:5432/scholarhub
SCHOLARHUB_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
SCHOLARHUB_ADMIN_EMAIL=admin@scholarhub.local
SCHOLARHUB_ADMIN_PASSWORD=changeme
SCHOLARHUB_CORS_ORIGINS=["http://localhost:5173","http://localhost:80","http://localhost"]
SCHOLARHUB_ALLOWED_HOSTS=localhost,127.0.0.1
SCHOLARHUB_RATE_LIMIT_PER_MINUTE=120
SCHOLARHUB_LOG_LEVEL=INFO
SCHOLARHUB_JSON_LOGS=false
UVICORN_WORKERS=2

# Frontend build-time configuration (used for static/GitHub Pages builds only).
# The Docker image reads runtime values from SCHOLARHUB_* variables below.
VITE_API_URL=http://localhost:8000/api
VITE_API_MODE=remote
VITE_ROUTER=browser
VITE_BASE_PATH=/

# Frontend runtime configuration (used by the production Docker image).
# These override the build-time defaults without rebuilding the image.
SCHOLARHUB_API_URL=/api
SCHOLARHUB_API_MODE=remote
SCHOLARHUB_ROUTER_MODE=browser
SCHOLARHUB_BASE_PATH=/
