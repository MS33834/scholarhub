# ScholarHUB environment configuration.
# Copy this file to `.env` at the repository root and replace all placeholder
# secrets with strong, unique values before running in any real environment.

# =============================================================================
# Database Configuration
# Used by both `infra/docker-compose.yml` (dev) and `infra/docker-compose.prod.yml`.
# =============================================================================
POSTGRES_USER=scholarhub
POSTGRES_PASSWORD=scholarhub
POSTGRES_DB=scholarhub

# =============================================================================
# Backend Configuration
# =============================================================================
# Connection string used by the backend. In Docker Compose the hostname is the
# service name (`db` for dev, `postgres` for prod). When running the backend
# directly on the host, use `localhost`.
SCHOLARHUB_DATABASE_URL=postgresql+asyncpg://scholarhub:scholarhub@localhost:5432/scholarhub

# JWT signing key. MUST be at least 32 characters and MUST be provided in
# every non-test environment. The application will refuse to start without it.
# Generate a secure value with: openssl rand -hex 32
SCHOLARHUB_SECRET_KEY=<generate-with-openssl-rand-hex-32>

# Initial administrator account. The password MUST be at least 12 characters
# and cannot be a common value (changeme, admin, password, etc.).
SCHOLARHUB_ADMIN_EMAIL=admin@scholarhub.local
SCHOLARHUB_ADMIN_USERNAME=admin
SCHOLARHUB_ADMIN_PASSWORD=<change-me-at-least-12-chars>

# Comma-separated list of allowed CORS origins. For local Docker the frontend
# is served on http://localhost.
SCHOLARHUB_CORS_ORIGINS=["http://localhost:5173","http://localhost:80","http://localhost"]

# Comma-separated list of trusted hosts. Required in production; `*` is allowed
# only for local development.
SCHOLARHUB_ALLOWED_HOSTS=localhost,127.0.0.1

SCHOLARHUB_RATE_LIMIT_PER_MINUTE=120
SCHOLARHUB_REDIS_URL=redis://localhost:6379/0
SCHOLARHUB_LOG_LEVEL=INFO
SCHOLARHUB_JSON_LOGS=false
UVICORN_WORKERS=2

# =============================================================================
# Frontend Build-time Configuration
# Used for static/GitHub Pages builds and as defaults when building the Docker
# image. The production Docker image can override these at runtime using the
# SCHOLARHUB_* variables below.
# =============================================================================
VITE_API_URL=http://localhost:8000/api
VITE_API_MODE=remote
VITE_ROUTER=browser
VITE_BASE_PATH=/

# =============================================================================
# Frontend Runtime Configuration
# Used by `infra/Dockerfile.frontend` / `infra/docker-entrypoint.frontend.sh` to
# inject settings without rebuilding the image.
# =============================================================================
SCHOLARHUB_API_URL=/api
SCHOLARHUB_API_MODE=remote
SCHOLARHUB_ROUTER_MODE=browser
SCHOLARHUB_BASE_PATH=/
